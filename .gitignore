# MacOS indexing file
.DS_STORE

# Backup files
*.bak

# IDEs
.idea
.vscode

# Config personnalisee (utiliser config.zsh.example comme base)
config.zsh

# Aliases locaux (utiliser aliases.local.zsh.example comme base)
aliases.local.zsh

# Fichier de tracking auto-update
.last_update_check

# Plugins (clonés localement)
plugins/

# LLM files
*.llmcache
*.llmdata

# Context files
*.context
*.ctx
CLAUDE.md
GEMINI.md
.claude
.gemini
.cursor
.cursorrules
.github/copilot-*

# Theme state et profiles (personnel)
.current_theme
profiles/

# Trust store pour .zsh-env.local
.trusted/

# env.d : fichiers en clair (les .sops.zsh peuvent etre versionnes)
env.d/*.zsh
!env.d/*.sops.zsh
!env.d/README.md

# Backups
backups/

# Rust CLI build artifacts
cli/target/

# Fichiers Work dechiffres (generes a partir des .enc)
work/settings.xml
work/certificates_unix.sh
.work_context_cache
